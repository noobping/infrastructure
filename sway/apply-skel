#!/usr/bin/env bash
set -euo pipefail

skel=/etc/skel

[[ -d "$skel" ]] || exit 0

getent passwd | while IFS=: read -r user _ uid gid _ home shell; do
  case "$uid" in
    ""|*[!0-9]*)
      continue
      ;;
  esac

  if (( uid < 1000 || uid >= 60000 )); then
    continue
  fi

  case "$home" in
    /home/*|/var/home/*)
      ;;
    *)
      continue
      ;;
  esac

  case "$shell" in
    */false|*/nologin)
      continue
      ;;
  esac

  if [[ ! -d "$home" ]]; then
    continue
  fi

  cp -an "$skel"/. "$home"/

  for entry in "$skel"/.[!.]* "$skel"/..?* "$skel"/*; do
    if [[ ! -e "$entry" && ! -L "$entry" ]]; then
      continue
    fi

    target="$home/$(basename "$entry")"
    if [[ -L "$target" ]]; then
      chown -h "$uid:$gid" "$target"
    elif [[ -e "$target" ]]; then
      chown -R "$uid:$gid" "$target"
    fi
  done

  if command -v restorecon >/dev/null 2>&1; then
    restorecon -RF "$home"
  fi
done
