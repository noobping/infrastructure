# Copy to /etc/ups/nut.env and fill in one profile.
# Keep the real file mode 0640 or stricter; it contains credentials.

# UniFi UPS over the network:
NUT_MODE=netclient
NUT_UPS_HOST=ups.example.lan
NUT_UPS_NAME=UPS
NUT_UPS_PORT=3493
NUT_MONITOR_USER=nut
NUT_MONITOR_PASSWORD=nut
NUT_POWER_VALUE=1
NUT_ROLE=secondary

# Local USB UPS attached to the NAS:
# NUT_MODE=standalone
# NUT_UPS_NAME=UPS
# NUT_DRIVER=usbhid-ups
# NUT_DEVICE_PORT=auto
# NUT_MONITOR_USER=upsmon
# NUT_MONITOR_PASSWORD=change-me
# NUT_ROLE=primary

# Local USB UPS attached to the NAS and shared to other machines:
# NUT_MODE=netserver
# NUT_UPS_NAME=UPS
# NUT_DRIVER=usbhid-ups
# NUT_DEVICE_PORT=auto
# NUT_MONITOR_USER=upsmon
# NUT_MONITOR_PASSWORD=change-me
# NUT_ROLE=primary
# NUT_REMOTE_MONITOR_USER=upsmon-remote
# NUT_REMOTE_MONITOR_PASSWORD=change-me-too
