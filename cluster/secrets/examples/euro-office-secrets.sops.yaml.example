# These two namespace-scoped Secrets must contain the exact same JWT value.
apiVersion: v1
kind: Secret
metadata:
  name: euro-office-secrets
  namespace: office
type: Opaque
stringData:
  # Use at least 32 random characters: openssl rand -hex 32
  jwt-secret: REPLACE_BEFORE_ENCRYPTING
---
apiVersion: v1
kind: Secret
metadata:
  name: euro-office-connector
  namespace: nextcloud
type: Opaque
stringData:
  jwt-secret: REPLACE_WITH_THE_SAME_VALUE_BEFORE_ENCRYPTING

