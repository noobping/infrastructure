#!/bin/sh
set -eu

container_name=uptime-kuma
attempt=0

while :; do
  attempt=$((attempt + 1))

  if podman exec "$container_name" node /bootstrap.js; then
    exit 0
  fi

  if [ "$attempt" -ge 60 ]; then
    echo "Uptime Kuma bootstrap failed after ${attempt} attempts" >&2
    exit 1
  fi

  sleep 10
done
