#!/usr/bin/bash
set -euo pipefail

storage_root=/var/srv/ssd
state_dir=${storage_root}/caddy

mount_target=$(findmnt --noheadings --raw --output TARGET --target "$storage_root")
filesystem=$(findmnt --noheadings --raw --output FSTYPE --target "$storage_root")

if [[ $mount_target != "$storage_root" || $filesystem != btrfs ]]; then
  echo "$storage_root must be a mounted Btrfs filesystem" >&2
  exit 1
fi

if [[ -e $state_dir ]]; then
  if ! btrfs subvolume show "$state_dir" >/dev/null 2>&1; then
    echo "$state_dir exists but is not a Btrfs subvolume" >&2
    exit 1
  fi
else
  btrfs subvolume create "$state_dir"
fi

chmod 0700 "$state_dir"
install -d -m 0700 "$state_dir/data" "$state_dir/config"
