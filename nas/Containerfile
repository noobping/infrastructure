ARG IMAGE_NAMESPACE=ghcr.io/noobping
FROM ${IMAGE_NAMESPACE}/ips:latest

LABEL org.opencontainers.image.title="NAS"
LABEL org.opencontainers.image.description="a bootable container"

RUN set -euxo pipefail; \
  if rpm -q nfs-utils-coreos >/dev/null 2>&1; then \
    rpm-ostree override remove nfs-utils-coreos; \
  fi; \
  rm -rf /var/cache/rpm-ostree /var/lib/rpm-ostree/cache /var/cache/dnf; \
  ostree container commit

RUN rpm-ostree install -y \
    libvirt qemu-kvm pcp-zeroconf smartmontools \
    cockpit-system cockpit-ostree cockpit-podman cockpit-machines cockpit-storaged cockpit-files cockpit-networkmanager cockpit-sosreport cockpit-kdump cockpit-selinux \
    gssproxy \
    nut \
    toolbox git tmux; \

  ln -s /var/srv/git /git; \
  rm -rf /var/cache/rpm-ostree /var/lib/rpm-ostree/cache /var/cache/dnf; \
  mkdir -p \
  /etc/nftables/rules \
  /etc/modules-load.d \
  /etc/polkit-1/rules.d \
  /etc/ups \
  /etc/systemd/system/multi-user.target.wants \
  /etc/systemd/system/timers.target.wants \
  /usr/libexec/infrastructure \
  /var/lib/suricata \
  /var/log/suricata \
  /var/www; \
  install -d -m 0755 -o 1007 -g 1007 /var/www/git; \
  ln -s /var/www/git /web; \
  ostree container commit

COPY fstab.txt /etc/fstab
COPY todo.sh /usr/bin/todo
COPY btrfs-backup /usr/libexec/infrastructure/btrfs-backup
COPY btrfs-backup.service /etc/systemd/system/btrfs-backup.service
COPY btrfs-backup.timer /etc/systemd/system/btrfs-backup.timer
COPY caddy.conf /etc/caddy.conf
COPY caddy-prepare /usr/libexec/infrastructure/caddy-prepare
COPY caddy-prepare.service /etc/systemd/system/caddy-prepare.service
COPY containers /etc/containers/systemd
COPY libvirtd.conf /etc/libvirt/libvirtd.conf
COPY localhost-registry.conf /etc/containers/registries.conf.d/10-localhost-registry.conf
COPY mdadm.conf /etc/mdadm.conf
COPY nextcloud-wildcard.config.php /etc/nextcloud-wildcard.config.php
COPY nut-configure /usr/libexec/infrastructure/nut-configure
COPY nut-configure.service /etc/systemd/system/nut-configure.service
COPY nut.env.example /etc/ups/nut.env.example
COPY paperless-prepare /usr/libexec/infrastructure/paperless-prepare
COPY paperless-prepare.service /etc/systemd/system/paperless-prepare.service
COPY polkit.rules /etc/polkit-1/rules.d/50-libvirt-access.rules
COPY nftables /etc/nftables/rules
COPY suricata.nft /etc/nftables/suricata.nft

RUN set -euxo pipefail; \
  chmod -R 0600 /etc/nftables/rules; \
  find /etc/containers/systemd -type f \( -name '*.container' -o -name '*.network' \) -exec chmod 0644 '{}' ';'; \
  chmod 0755 \
    /usr/libexec/infrastructure/btrfs-backup \
    /usr/libexec/infrastructure/caddy-prepare \
    /usr/libexec/infrastructure/paperless-prepare; \
  awk '/set allowed_tcp_dports[[:space:]]*\{/{flag=1} flag{print} /^\t*\}/{if(flag){exit}}' /etc/nftables/main.nft \
  | grep -q '\<http\>' \
  || sed -i '/set allowed_tcp_dports[[:space:]]*{/,/}/{/elements = {/ s/}/, http, https}/;}' /etc/nftables/main.nft; \
  grep -q 'include "/etc/nftables/rules/\\*.nft"' /etc/nftables/main.nft \
  || sed -i '/tcp dport @allowed_tcp_dports accept/i\        include "/etc/nftables/rules/*.nft"' /etc/nftables/main.nft; \
  grep -q 'include "/etc/nftables/suricata.nft"' /etc/nftables/main.nft \
  || printf '\ninclude "/etc/nftables/suricata.nft"\n' >> /etc/nftables/main.nft; \
  ln -sf /usr/lib/systemd/system/libvirtd.service \
    /etc/systemd/system/multi-user.target.wants/libvirtd.service; \
  ln -sf /usr/lib/systemd/system/virtlockd.service \
    /etc/systemd/system/multi-user.target.wants/virtlockd.service; \
  ln -sf /usr/lib/systemd/system/virtlogd.service \
    /etc/systemd/system/multi-user.target.wants/virtlogd.service; \
  ln -sf /etc/systemd/system/nut-configure.service \
    /etc/systemd/system/multi-user.target.wants/nut-configure.service; \
  ln -sf /etc/systemd/system/paperless-prepare.service \
    /etc/systemd/system/multi-user.target.wants/paperless-prepare.service; \
  ln -sf /etc/systemd/system/btrfs-backup.timer \
    /etc/systemd/system/timers.target.wants/btrfs-backup.timer; \
  ostree container commit
