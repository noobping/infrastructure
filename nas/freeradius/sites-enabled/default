server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        filter_username
        preprocess
        suffix
        files
        expiration
        logintime
        ldap

        if (!(LDAP-Group == "cn=radius-users,cn=groups,cn=accounts,dc=nick,dc=nas")) {
            reject
        }

        if (!control:Auth-Type && User-Password) {
            update control {
                Auth-Type := ldap
            }
        }

        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }

        Auth-Type LDAP {
            ldap
        }
    }

    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        detail
    }

    session {
    }

    post-auth {
    }
}
