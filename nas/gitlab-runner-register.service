[Unit]
Description=Register the local GitLab Runner
Wants=network-online.target gitlab.service registry.service sshd.service
After=network-online.target gitlab.service registry.service sshd.service
ConditionPathExists=/var/lib/containers/gitlab-runner/secrets/runner-token
ConditionPathExists=!/var/lib/containers/gitlab-runner/config/config.toml

[Service]
Type=oneshot
ExecStart=/usr/libexec/infrastructure/gitlab-runner-register

[Install]
WantedBy=multi-user.target
