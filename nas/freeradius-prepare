#!/bin/sh
set -eu

config_dir=/var/lib/containers/freeradius/config
secrets_dir=/var/lib/containers/secrets
template_dir=/usr/share/freeradius
ldap_template="$template_dir/mods-enabled/ldap.template"
ldap_output="$config_dir/mods-enabled/ldap"
ldap_bind_password_file="$secrets_dir/ldap-bind-password"
clients_secret_file="$secrets_dir/clients.conf"

install -d -m 0755 "$config_dir" "$config_dir/mods-enabled" "$secrets_dir"

[ -s "$ldap_bind_password_file" ] || {
  echo "Missing FreeRADIUS LDAP bind password: $ldap_bind_password_file" >&2
  exit 1
}
[ -s "$clients_secret_file" ] || {
  echo "Missing FreeRADIUS client definitions: $clients_secret_file" >&2
  exit 1
}

ldap_bind_password=$(tr -d '\r' < "$ldap_bind_password_file")
escaped_bind_password=$(printf '%s' "$ldap_bind_password" | sed 's/[|\\&]/\\&/g')

sed "s|__LDAP_BIND_PASSWORD__|$escaped_bind_password|g" "$ldap_template" > "$ldap_output"
chmod 0600 "$ldap_output"

if command -v restorecon >/dev/null 2>&1; then
  restorecon -RF "$config_dir" "$secrets_dir" || true
fi
