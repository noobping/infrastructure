[Unit]
Description=Uptime Kuma
ConditionPathExists=/var/lib/containers/uptime-kuma

[Container]
Image=docker.io/louislam/uptime-kuma:2
ContainerName=uptime-kuma
AutoUpdate=registry
PodmanArgs=--network=host
SecurityLabelDisable=true
Volume=/var/lib/containers/uptime-kuma:/app/data
Volume=/var/lib/containers/secrets:/run/uptime-kuma-secrets:ro
Volume=/usr/libexec/infrastructure/uptime-kuma-bootstrap.js:/bootstrap.js:ro
Volume=/usr/share/infrastructure/uptime-kuma/config.json:/bootstrap-config.json:ro

[Service]
Restart=always
TimeoutStartSec=900
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
