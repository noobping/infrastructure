[Unit]
Description=Podman - caddy web service

[Container]
Image=docker.io/library/caddy:latest
AutoUpdate=registry
Memory=256M
PidsLimit=256
ShmSize=7168b
PodmanArgs=--network=host -v /etc/caddy.conf:/etc/caddy/Caddyfile:Z -v /var/www/git:/srv/web:Z

[Service]
Restart=always
RestartSec=5
TimeoutStartSec=900
MemoryHigh=384M
MemoryMax=512M
CPUQuota=50%
IOWeight=100

[Install]
WantedBy=default.target
