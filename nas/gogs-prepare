#!/bin/sh
set -eu

base_dir=/var/lib/containers/gogs
data_dir=${base_dir}/data
conf_dir=${base_dir}/conf
app_ini=${conf_dir}/app.ini
secret_file=${conf_dir}/secret_key

host_ip=$(
  ip -4 route get 1.1.1.1 2>/dev/null \
  | awk '{for (i = 1; i <= NF; i++) if ($i == "src") { print $(i + 1); exit }}'
)

if [ -z "${host_ip}" ]; then
  host_ip=$(
    ip -4 -o addr show scope global up 2>/dev/null \
    | awk '{split($4, addr, "/"); print addr[1]; exit}'
  )
fi

: "${host_ip:=127.0.0.1}"

install -d -m 0750 "${data_dir}" "${conf_dir}"

if [ ! -s "${secret_file}" ]; then
  tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64 > "${secret_file}"
  printf '\n' >> "${secret_file}"
  chmod 0640 "${secret_file}"
fi

secret_key=$(tr -d '\n' < "${secret_file}")
tmp_app_ini=$(mktemp "${conf_dir}/app.ini.XXXXXX")

cleanup() {
  rm -f "${tmp_app_ini}"
}
trap cleanup EXIT HUP INT TERM

cat > "${tmp_app_ini}" <<EOF
BRAND_NAME = Gogs
RUN_USER = git
RUN_MODE = prod

[server]
EXTERNAL_URL = http://${host_ip}:8929/
DOMAIN = ${host_ip}
PROTOCOL = http
HTTP_ADDR = 0.0.0.0
HTTP_PORT = 3000
LOCAL_ROOT_URL = http://127.0.0.1:3000/
APP_DATA_PATH = /data/gogs/data
START_SSH_SERVER = true
SSH_DOMAIN = ${host_ip}
SSH_PORT = 2222
SSH_LISTEN_HOST = 0.0.0.0
SSH_LISTEN_PORT = 2222
SSH_ROOT_PATH = /data/ssh
OFFLINE_MODE = false
LANDING_URL = /

[repository]
ROOT = /data/git/gogs-repositories

[database]
TYPE = sqlite3
PATH = /data/gogs/data/gogs.db

[security]
INSTALL_LOCK = true
SECRET_KEY = ${secret_key}
COOKIE_SECURE = false

[session]
PROVIDER = file
PROVIDER_CONFIG = /data/gogs/data/sessions
COOKIE_SECURE = false

[log]
ROOT_PATH = /data/gogs/log
EOF

chmod 0640 "${tmp_app_ini}"
mv -f "${tmp_app_ini}" "${app_ini}"
