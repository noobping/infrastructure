[Unit]
Description=Bootstrap FreeIPA group and bind user for FreeRADIUS
Wants=freeipa.service
After=freeipa.service network-online.target
Requires=freeipa.service
Before=freeradius.service
ConditionPathExists=/var/lib/containers/secrets/admin-password
ConditionPathExists=/var/lib/containers/secrets/ds-password
ConditionPathExists=/var/lib/containers/secrets/ldap-bind-password

[Service]
Type=oneshot
ExecStart=/usr/libexec/infrastructure/freeipa-bootstrap-radius
