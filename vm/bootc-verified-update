#!/bin/sh
set -eu

rpm_ostree_image_ref() {
  printf 'ostree-image-signed:docker://%s\n' "$1"
}

default_container_ref() {
  jq -er '
    .deployments[0]["container-image-reference"]
    | select(type == "string" and length > 0)
  '
}

image_repository() {
  name_and_tag="${1%%@*}"
  repository="$name_and_tag"
  case "${name_and_tag##*/}" in
    *:*) repository="${name_and_tag%:*}" ;;
  esac
  printf '%s\n' "$repository"
}

valid_verified_ref() {
  candidate="$1"
  expected_repository="$2"

  case "$candidate" in
    ''|*[[:space:]]*) return 1 ;;
    *@*) ;;
    *) return 1 ;;
  esac

  candidate_repository="${candidate%@*}"
  candidate_digest="${candidate##*@}"
  case "$candidate_repository" in
    ''|*@*) return 1 ;;
  esac
  [ "$candidate_repository" = "$expected_repository" ] || return 1
  case "${candidate_repository##*/}" in
    ''|*:*) return 1 ;;
  esac

  case "$candidate_digest" in
    sha256:*) digest_hex="${candidate_digest#sha256:}" ;;
    *) return 1 ;;
  esac
  case "$digest_hex" in
    ''|*[!0123456789abcdef]*) return 1 ;;
  esac
  [ "${#digest_hex}" -eq 64 ]
}

assert_valid() {
  candidate="$1"
  expected_repository="$2"
  if ! valid_verified_ref "$candidate" "$expected_repository"; then
    echo "expected a valid verified reference: $candidate" >&2
    return 1
  fi
}

assert_invalid() {
  candidate="$1"
  expected_repository="$2"
  if valid_verified_ref "$candidate" "$expected_repository"; then
    echo "expected an invalid verified reference: $candidate" >&2
    return 1
  fi
}

self_test() {
  digest="sha256:$(printf '%064d' 0)"
  assert_valid "ghcr.io/noobping/nas@$digest" ghcr.io/noobping/nas
  assert_valid \
    "registry.example:5000/team/image@$digest" \
    registry.example:5000/team/image
  assert_valid \
    "[2001:db8::1]:5000/team/image@$digest" \
    "[2001:db8::1]:5000/team/image"
  assert_invalid "ghcr.io/noobping/nas:latest@$digest" ghcr.io/noobping/nas
  assert_invalid "ghcr.io/noobping/nas@sha256:1234" ghcr.io/noobping/nas
  assert_invalid "ghcr.io/noobping/nas@sha256:$(printf '%064d' 0 | tr 0 g)" ghcr.io/noobping/nas
  assert_invalid "ghcr.io/noobping/nas@extra@$digest" ghcr.io/noobping/nas
  assert_invalid "ghcr.io/noobping/other@$digest" ghcr.io/noobping/nas

  verified_ref="ghcr.io/noobping/nas@$digest"
  expected_origin="ostree-image-signed:docker://$verified_ref"
  actual_origin="$(rpm_ostree_image_ref "$verified_ref")"
  if [ "$actual_origin" != "$expected_origin" ]; then
    echo "unexpected rpm-ostree image reference: $actual_origin" >&2
    return 1
  fi

  default_ref="$(
    printf '%s\n' \
      '{"deployments":[{"container-image-reference":"desired"},{"booted":true,"container-image-reference":"rollback"}]}' \
      | default_container_ref
  )"
  if [ "$default_ref" != desired ]; then
    echo "unexpected default container reference: $default_ref" >&2
    return 1
  fi
  if printf '%s\n' '{"deployments":[{}]}' \
    | default_container_ref >/dev/null 2>&1; then
    echo "accepted a missing default container reference" >&2
    return 1
  fi

  echo "bootc-verified-update self-test: OK"
}

if [ "${1-}" = --self-test ]; then
  [ "$#" -eq 1 ] || { echo "Usage: $0 --self-test" >&2; exit 2; }
  self_test
  exit 0
fi

tracked_ref_file=/etc/bootc-image-ref
if [ -x /usr/libexec/infrastructure/verify-bootc-image ]; then
  verifier=/usr/libexec/infrastructure/verify-bootc-image
elif [ -x /usr/local/libexec/infrastructure/verify-bootc-image ]; then
  verifier=/usr/local/libexec/infrastructure/verify-bootc-image
else
  echo "the bootc image signature verifier is missing" >&2
  exit 1
fi

if [ ! -r "$tracked_ref_file" ]; then
  echo "tracked bootc image reference is missing: $tracked_ref_file" >&2
  exit 1
fi

image_ref="$(awk 'NF && $1 !~ /^#/ { print $1; exit }' "$tracked_ref_file")"
if [ -z "$image_ref" ]; then
  echo "tracked bootc image reference is empty: $tracked_ref_file" >&2
  exit 1
fi

expected_repository="$(image_repository "$image_ref")"
verified_ref="$($verifier "$image_ref")"
if ! valid_verified_ref "$verified_ref" "$expected_repository"; then
  echo "verifier returned an invalid tag-free digest reference" >&2
  exit 1
fi

origin="$(rpm_ostree_image_ref "$verified_ref")"
echo "Staging verified bootc image: $verified_ref"
if status_json="$(rpm-ostree status --json)" \
  && current_origin="$(printf '%s\n' "$status_json" | default_container_ref)" \
  && [ "$current_origin" = "$origin" ]; then
  echo "Verified bootc image is already staged: $verified_ref"
  exit 0
fi

exec rpm-ostree rebase "$origin"
