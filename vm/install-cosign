#!/bin/sh
set -eu

version=v3.0.6
target="${1:-/usr/local/bin/cosign}"

case "$(uname -m)" in
  x86_64) asset=cosign-linux-amd64; expected=c956e5dfcac53d52bcf058360d579472f0c1d2d9b69f55209e256fe7783f4c74 ;;
  aarch64) asset=cosign-linux-arm64; expected=bedac92e8c3729864e13d4a17048007cfafa79d5deca993a43a90ffe018ef2b8 ;;
  *) echo "unsupported Cosign architecture: $(uname -m)" >&2; exit 1 ;;
esac

if [ -f "$target" ]; then
  actual="$(sha256sum "$target" | awk '{ print $1 }')"
  if [ "$actual" = "$expected" ]; then
    exit 0
  fi
fi

tmp="$(mktemp /tmp/cosign.XXXXXX)"
trap 'rm -f "$tmp"' EXIT HUP INT TERM

curl \
  --fail \
  --location \
  --proto '=https' \
  --retry 5 \
  --tlsv1.2 \
  --output "$tmp" \
  "https://github.com/sigstore/cosign/releases/download/${version}/${asset}"
printf '%s  %s\n' "$expected" "$tmp" \
  | sha256sum --check --strict -
install -D -o root -g root -m 0755 "$tmp" "$target"
