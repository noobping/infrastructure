#!/bin/sh
set -eu

state_root=/var/lib/infrastructure/backup/minecraft
quiesce_root="$state_root/quiesce"
java_marker="$quiesce_root/java-save-off"
bedrock_marker="$quiesce_root/bedrock-save-hold"
finish_hook=${MINECRAFT_BACKUP_FINISH_HOOK:-/usr/libexec/infrastructure/backup-finish}

cleanup() {
  status=$?
  trap - EXIT INT TERM
  set +e
  if ! "$finish_hook"; then
    [ "$status" -ne 0 ] || status=1
  fi
  exit "$status"
}
trap cleanup EXIT INT TERM

install -d -o root -g root -m 0700 "$state_root"
# Recover a save-off/hold left by an interrupted previous attempt before
# quiescing the containers again.
"$finish_hook"
install -d -o root -g root -m 0700 "$quiesce_root"

container_running() {
  [ "$(podman inspect --format '{{.State.Status}}' "$1" 2>/dev/null || true)" = running ]
}

if container_running systemd-minecraft; then
  : > "$java_marker"
  podman exec systemd-minecraft rcon-cli save-off >/dev/null
  podman exec systemd-minecraft rcon-cli save-all flush >/dev/null
fi

if container_running systemd-bedrock; then
  log_since="$(date --iso-8601=seconds)"
  : > "$bedrock_marker"
  podman exec systemd-bedrock send-command save hold >/dev/null

  ready=
  attempts=0
  while [ "$attempts" -lt 30 ]; do
    podman exec systemd-bedrock send-command save query >/dev/null || true
    if podman logs --since "$log_since" systemd-bedrock 2>&1 \
      | grep -Fq 'Files are now ready to be copied'; then
      ready=1
      break
    fi
    attempts=$((attempts + 1))
    sleep 2
  done
  [ -n "$ready" ] || {
    echo "Bedrock did not make its world files ready within 60 seconds" >&2
      exit 1
    }

fi

# Flush the NFS writes before the NAS snapshots the exported directories.
sync

trap - EXIT INT TERM
