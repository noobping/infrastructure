[Unit]
Description=Minecraft Bedrock data on the NAS
Wants=network-online.target
After=network-online.target cachefilesd.service nfs-selinux.service
Requires=cachefilesd.service nfs-selinux.service

[Volume]
Type=nfs
Device=:/var/lib/containers/minecraft/bedrock
Options=addr=nas.vm,nfsvers=4.2,fsc,nosuid,nodev
Copy=false
