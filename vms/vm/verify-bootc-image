#!/bin/sh
set -eu

image_repository() {
  name_and_tag="${1%%@*}"
  repository="$name_and_tag"
  case "${name_and_tag##*/}" in
    *:*) repository="${name_and_tag%:*}" ;;
  esac
  printf '%s\n' "$repository"
}

assert_repository() {
  input="$1"
  expected="$2"
  actual="$(image_repository "$input")"
  if [ "$actual" != "$expected" ]; then
    echo "repository test failed: $input: expected $expected, got $actual" >&2
    return 1
  fi
}

self_test() {
  digest="sha256:$(printf '%064d' 0)"
  assert_repository ghcr.io/noobping/nas ghcr.io/noobping/nas
  assert_repository ghcr.io/noobping/nas:latest ghcr.io/noobping/nas
  assert_repository "ghcr.io/noobping/nas@$digest" ghcr.io/noobping/nas
  assert_repository "ghcr.io/noobping/nas:latest@$digest" ghcr.io/noobping/nas
  assert_repository \
    registry.example:5000/team/image:tag \
    registry.example:5000/team/image
  assert_repository \
    "[2001:db8::1]:5000/team/image:tag@$digest" \
    "[2001:db8::1]:5000/team/image"
  echo "verify-bootc-image self-test: OK"
}

if [ "${1-}" = --self-test ]; then
  [ "$#" -eq 1 ] || { echo "Usage: $0 --self-test" >&2; exit 2; }
  self_test
  exit 0
fi

if [ "$#" -ne 1 ]; then
  echo "Usage: $0 IMAGE_REFERENCE" >&2
  exit 2
fi

image_ref="$1"
case "$image_ref" in
  ''|*[[:space:]]*) echo "invalid image reference: $image_ref" >&2; exit 2 ;;
esac

if [ -x /usr/libexec/infrastructure/install-cosign ]; then
  installer=/usr/libexec/infrastructure/install-cosign
elif [ -x /usr/local/libexec/infrastructure/install-cosign ]; then
  installer=/usr/local/libexec/infrastructure/install-cosign
else
  echo "the pinned Cosign installer is missing" >&2
  exit 1
fi

if [ -x /usr/bin/cosign ]; then
  cosign=/usr/bin/cosign
  cosign_target=/usr/bin/cosign
else
  cosign=/usr/local/bin/cosign
  cosign_target=/usr/local/bin/cosign
fi
"$installer" "$cosign_target" >&2

repository="$(image_repository "$image_ref")"
image_name="${repository##*/}"
case "$repository" in
  "ghcr.io/noobping/${image_name}") ;;
  *)
    echo "image is outside the trusted GHCR namespace: $image_ref" >&2
    exit 1
    ;;
esac
case "$image_name" in
  vm|minecraft|jellyfin|k3s) workflow=vms.yml ;;
  nas) workflow=nas.yml ;;
  workstation) workflow=workstation.yml ;;
  sway) workflow=sway.yml ;;
  *)
    echo "no trusted signing workflow is configured for image: $image_ref" >&2
    exit 1
    ;;
esac
identity="https://github.com/noobping/infrastructure/.github/workflows/${workflow}@refs/heads/main"
issuer=https://token.actions.githubusercontent.com
verification="$(mktemp /tmp/bootc-cosign.XXXXXX)"
index="$(mktemp /tmp/bootc-index.XXXXXX)"
trap 'rm -f "$verification" "$index"' EXIT HUP INT TERM

verify() {
  "$cosign" verify \
    --output=json \
    --certificate-identity="$identity" \
    --certificate-oidc-issuer="$issuer" \
    "$1" > "$verification"
}

verification_ref="$image_ref"
case "$image_ref" in
  *@*) verification_ref="${repository}@${image_ref#*@}" ;;
esac

if ! verify "$verification_ref"; then
  case "$image_name" in
    workstation|sway) ;;
    *) exit 1 ;;
  esac

  case "$(uname -m)" in
    x86_64) architecture=amd64 ;;
    aarch64) architecture=arm64 ;;
    *) echo "unsupported image architecture: $(uname -m)" >&2; exit 1 ;;
  esac

  echo "The index is unsigned; checking its signed $architecture platform manifest" >&2
  skopeo inspect --raw "docker://${verification_ref}" > "$index"
  platform_digest="$(
    jq -er --arg architecture "$architecture" \
      '[.manifests[]? | select(.platform.os == "linux" and .platform.architecture == $architecture) | .digest | select(type == "string" and test("^sha256:[0-9a-f]{64}$"))] | unique | if length == 1 then .[0] else error("expected exactly one platform digest") end' \
      "$index"
  )"
  verify "${repository}@${platform_digest}"
fi

digest="$(
  jq -er '
    [.[].critical.image["docker-manifest-digest"]
      | select(type == "string"
          and test("^sha256:[0-9a-f]{64}$"))]
    | unique
    | if length == 1 then
        .[0]
      else
        error("verification did not return exactly one manifest digest")
      end
  ' "$verification"
)"

printf '%s@%s\n' "$repository" "$digest"
