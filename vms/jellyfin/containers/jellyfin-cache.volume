[Unit]
Description=Jellyfin cache on the NAS
Wants=network-online.target
After=network-online.target cachefilesd.service nfs-selinux.service
Requires=cachefilesd.service nfs-selinux.service

[Volume]
Type=nfs
Device=:/var/lib/containers/jellyfin/cache
Options=addr=nas.vm,nfsvers=4.2,fsc,nosuid,nodev,noexec
Copy=false
