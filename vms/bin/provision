#!/usr/bin/bash
set -euo pipefail

repository_root=$(cd "$(dirname "$0")/../.." && pwd)
inventory="$repository_root/vms/inventory.json"
template="$repository_root/vms/libvirt/domain.xml.in"
start_vms=0
declare -a requested=()

usage() {
  cat <<'USAGE'
Usage:
  sudo vms/bin/provision [--start] [--inventory FILE] NAME...
  sudo vms/bin/provision [--start] --all

The canonical role Ignition files must exist at dist/ign/{k3s,minecraft,jellyfin}.ign.
The command is create-only: it refuses to overwrite domains or disks.
USAGE
}

while (( $# > 0 )); do
  case "$1" in
    --start)
      start_vms=1
      shift
      ;;
    --inventory)
      (( $# >= 2 )) || { usage >&2; exit 2; }
      inventory=$2
      shift 2
      ;;
    --all)
      requested=(k3s minecraft jellyfin)
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      requested+=("$1")
      shift
      ;;
  esac
done

if (( EUID != 0 )); then
  echo "Provisioning must run as root" >&2
  exit 1
fi
if (( ${#requested[@]} == 0 )); then
  usage >&2
  exit 2
fi
if [[ $(uname -m) != x86_64 ]]; then
  echo "This libvirt template currently targets an x86_64 KVM NAS" >&2
  exit 1
fi

for command in coreos-installer ignition-validate jq qemu-img virsh; do
  command -v "$command" >/dev/null || {
    echo "Required command is missing: $command" >&2
    exit 1
  }
done

jq --exit-status '
  .version == 1
  and (.storage_pool.path | type == "string")
  and (.vms | type == "array" and length > 0)
  and ([.vms[].name] | length == (unique | length))
  and ([.vms[].mac] | length == (unique | length))
  and all(.vms[];
    (.name | test("^[a-z0-9-]+$"))
    and (.mac | test("^52:54:00:([0-9a-f]{2}:){2}[0-9a-f]{2}$"))
    and (.vcpus > 0)
    and (.memory_mib > 0)
    and (.root_gib >= 40)
  )
' "$inventory" >/dev/null

vm_root=$(jq --raw-output '.storage_pool.path' "$inventory")
pool_name=$(jq --raw-output '.storage_pool.name' "$inventory")
fcos_stream=$(jq --raw-output '.storage_pool.fcos_stream' "$inventory")

btrfs subvolume show "$vm_root" >/dev/null || {
  echo "$vm_root must already be a Btrfs subvolume" >&2
  exit 1
}

install -d -o root -g qemu -m 0770 \
  "$vm_root/base" \
  "$vm_root/config" \
  "$vm_root/disks" \
  "$vm_root/ignition"
restorecon -RF "$vm_root"

ip link show br0 >/dev/null 2>&1 || {
  echo "br0 does not exist. Run sudo nas-vm-bridge apply first." >&2
  exit 1
}

base_pattern="fedora-coreos-*-qemu.x86_64.qcow2"
base_image=$(find "$vm_root/base" -maxdepth 1 -type f -name "$base_pattern" \
  -printf '%p\n' | sort | tail -n 1)
if [[ -z $base_image ]]; then
  coreos-installer download \
    --stream "$fcos_stream" \
    --architecture x86_64 \
    --platform qemu \
    --format qcow2.xz \
    --decompress \
    --directory "$vm_root/base"
  base_image=$(find "$vm_root/base" -maxdepth 1 -type f -name "$base_pattern" \
    -printf '%p\n' | sort | tail -n 1)
fi
[[ -n $base_image ]] || {
  echo "coreos-installer did not produce a QEMU qcow2 image" >&2
  exit 1
}
chown root:qemu "$base_image"
chmod 0440 "$base_image"
restorecon "$base_image"

provision_one() (
  local name=$1
  local vm_json ignition_source ignition_file xml_file
  local root_disk root_new ignition_new xml_new
  local vcpus memory_mib root_gib mac autostart
  local completed=0 finalized=0 define_attempted=0

  vm_json=$(jq --compact-output --arg name "$name" \
    '.vms[] | select(.name == $name)' "$inventory")
  [[ -n $vm_json ]] || {
    echo "VM is not present in inventory: $name" >&2
    return 1
  }

  ignition_source=$(jq --raw-output '.ignition' <<< "$vm_json")
  if [[ $ignition_source != /* ]]; then
    ignition_source="$repository_root/$ignition_source"
  fi
  [[ -r $ignition_source ]] || {
    echo "Missing canonical Ignition for $name: $ignition_source" >&2
    echo "Render the guest configs described in butane/README.md first." >&2
    return 1
  }

  if virsh dominfo "$name" >/dev/null 2>&1; then
    echo "Domain already exists; refusing to replace it: $name" >&2
    return 1
  fi

  root_disk="$vm_root/disks/$name-root.qcow2"
  ignition_file="$vm_root/ignition/$name.ign"
  xml_file="$vm_root/config/$name.xml"
  for path in "$root_disk" "$ignition_file" "$xml_file"; do
    [[ ! -e $path ]] || {
      echo "Provisioning output already exists; refusing to overwrite: $path" >&2
      return 1
    }
  done

  vcpus=$(jq --raw-output '.vcpus' <<< "$vm_json")
  memory_mib=$(jq --raw-output '.memory_mib' <<< "$vm_json")
  root_gib=$(jq --raw-output '.root_gib' <<< "$vm_json")
  mac=$(jq --raw-output '.mac' <<< "$vm_json")
  autostart=$(jq --raw-output '.autostart' <<< "$vm_json")

  echo "Provisioning $name from the FCOS base image"
  echo "  CPU/RAM: $vcpus vCPU / $memory_mib MiB"
  echo "  disk: $root_gib GiB root"

  root_new="$root_disk.new"
  ignition_new="$ignition_file.new"
  xml_new="$xml_file.new"

  cleanup_provision() {
    local status=$?
    local can_remove=1
    trap - EXIT INT TERM
    set +e

    rm -f -- "$root_new" "$ignition_new" "$xml_new"

    if (( ! completed && define_attempted )) \
      && virsh dominfo "$name" >/dev/null 2>&1; then
      virsh destroy "$name" >/dev/null 2>&1 || true
      if ! virsh undefine "$name" >/dev/null; then
        echo "URGENT: failed to undefine partially provisioned domain $name" >&2
        can_remove=0
      fi
    fi

    if (( ! completed && finalized && can_remove )); then
      rm -f -- "$root_disk" "$ignition_file" "$xml_file"
      virsh pool-refresh "$pool_name" >/dev/null 2>&1 || true
    fi

    exit "$status"
  }
  trap cleanup_provision EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM
  rm -f -- "$root_new" "$ignition_new" "$xml_new"

  qemu-img create \
    -f qcow2 \
    -F qcow2 \
    -b "$base_image" \
    -o cluster_size=2M,lazy_refcounts=on \
    "$root_new" "${root_gib}G"
  install -m 0640 "$ignition_source" "$ignition_new"
  ignition-validate "$ignition_new"

  sed \
    -e "s|@NAME@|$name|g" \
    -e "s|@MEMORY_MIB@|$memory_mib|g" \
    -e "s|@VCPUS@|$vcpus|g" \
    -e "s|@ROOT_DISK@|$root_disk|g" \
    -e "s|@MAC@|$mac|g" \
    -e "s|@IGNITION@|$ignition_file|g" \
    "$template" > "$xml_new"

  if command -v virt-xml-validate >/dev/null 2>&1; then
    virt-xml-validate "$xml_new" domain
  fi

  finalized=1
  mv "$root_new" "$root_disk"
  mv "$ignition_new" "$ignition_file"
  mv "$xml_new" "$xml_file"
  chown root:qemu "$root_disk" "$ignition_file" "$xml_file"
  chmod 0660 "$root_disk"
  chmod 0640 "$ignition_file" "$xml_file"
  restorecon "$root_disk" "$ignition_file" "$xml_file"

  virsh pool-refresh "$pool_name" >/dev/null
  define_attempted=1
  virsh define "$xml_file" >/dev/null
  if [[ $autostart == true ]]; then
    virsh autostart "$name" >/dev/null
  fi
  if (( start_vms )); then
    virsh start "$name"
  fi

  completed=1
  echo "$name is defined with MAC $mac"
)

for name in "${requested[@]}"; do
  provision_one "$name"
done
