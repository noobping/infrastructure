#!/bin/sh
set -eu

CI_ROOT=${CI_ROOT:-$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)}
PATH="${CI_ROOT}/.ci/alias:${PATH}"
export CI_ROOT PATH

. "${CI_ROOT}/.ci/lib/common.sh"

CI_EVENT=${1:-}
export CI_EVENT

should_run=0
case "${CI_EVENT}" in
  manual)
    should_run=1
    ;;
  pre-push)
    if ci_should_run_on_push \
      '.ci/*' '.ci/*/*' '.ci/*/*/*' \
      '.workflow/butane' \
      'butane/*' 'butane/*/*'; then
      should_run=1
    fi
    ;;
esac

[ "${should_run}" -eq 1 ] || exit 3

if ci_test_mode; then
  ci_test_log "public:butane:${CI_EVENT}"
  exit 0
fi

embed_image=1
case "${CI_BUTANE_EMBED_IMAGE:-false}" in
  true|1|yes)
    ;;
  false|0|no)
    embed_image=0
    ;;
  *)
    ci_die "CI_BUTANE_EMBED_IMAGE must be true or false"
    ;;
esac

machine_arch=$(ci_current_machine_arch)

yq ea '. as $item ireduce ({}; . *+ $item)' butane/base.yml butane/setup.yml > butane/setup.bu
yq ea '. as $item ireduce ({}; . *+ $item)' \
  butane/base.yml \
  butane/updates.yml \
  butane/workstation.yml > butane/workstation.bu

sed "s#__CI_IMAGE_NAMESPACE__#${CI_IMAGE_NAMESPACE}#g" butane/setup.bu > butane/setup.rendered.bu
sed "s#__CI_IMAGE_NAMESPACE__#${CI_IMAGE_NAMESPACE}#g" butane/workstation.bu > butane/workstation.rendered.bu

butane --pretty --strict --files-dir . butane/setup.rendered.bu > setup.ign
butane --pretty --strict --files-dir . butane/workstation.rendered.bu > workstation.ign

coreos-installer download \
  -s stable \
  -a "${machine_arch}" \
  -p metal \
  -f iso \
  -C . \
  --decompress

base_iso=$(ls -1 fedora-coreos-*-live-iso."${machine_arch}".iso | tail -n 1)
out_iso="workstation-${machine_arch}.iso"

set -- \
  --live-ignition setup.ign \
  --dest-ignition workstation.ign \
  --pre-install butane/detect-device.sh \
  -o "${out_iso}" \
  "${base_iso}"

if [ "${embed_image}" -eq 1 ]; then
  mkdir -p bootc
  image_ref="${CI_IMAGE_NAMESPACE}/workstation:latest"
  archive_path="bootc/workstation.ociarchive"
  digest_path="${archive_path}.sha256"

  ci_podman_pull "${image_ref}"
  podman save --format oci-archive -o "${archive_path}" "${image_ref}"
  sha256sum "${archive_path}" | awk '{ print $1 }' > "${digest_path}"

  set -- \
    --live-ignition setup.ign \
    --dest-ignition workstation.ign \
    --pre-install butane/detect-device.sh \
    --post-install butane/cache-bootc-image.sh \
    -o "${out_iso}" \
    "${base_iso}"
fi

coreos-installer iso customize "$@"

if [ "${embed_image}" -eq 1 ]; then
  xorriso \
    -dev "${out_iso}" \
    -map "${archive_path}" "/bootc/workstation.ociarchive" \
    -map "${digest_path}" "/bootc/workstation.ociarchive.sha256" \
    -boot_image any replay \
    -compliance no_emul_toc \
    -padding included
fi

sha256sum "${out_iso}" > "${out_iso}.sha256"
