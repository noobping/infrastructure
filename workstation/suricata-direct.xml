<?xml version="1.0" encoding="utf-8"?>
<direct>
  <chain ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT"/>
  <chain ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT"/>
  <chain ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT"/>
  <chain ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT"/>

  <rule ipv="ipv4" table="filter" chain="INPUT" priority="0">-m mark ! --mark 0x1/0x1 -j SURICATA_HOST_INPUT</rule>
  <rule ipv="ipv4" table="filter" chain="OUTPUT" priority="0">-m mark ! --mark 0x1/0x1 -j SURICATA_HOST_OUTPUT</rule>
  <rule ipv="ipv6" table="filter" chain="INPUT" priority="0">-m mark ! --mark 0x1/0x1 -j SURICATA_HOST_INPUT</rule>
  <rule ipv="ipv6" table="filter" chain="OUTPUT" priority="0">-m mark ! --mark 0x1/0x1 -j SURICATA_HOST_OUTPUT</rule>

  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="0">-m conntrack --ctstate ESTABLISHED,RELATED -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="1">-i lo -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="2">-i virbr+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="3">-i vnet+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="4">-i podman+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="5">-i cni+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_INPUT" priority="6">-j NFQUEUE --queue-num 0</rule>

  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="0">-m conntrack --ctstate ESTABLISHED,RELATED -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="1">-o lo -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="2">-o virbr+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="3">-o vnet+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="4">-o podman+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="5">-o cni+ -j RETURN</rule>
  <rule ipv="ipv4" table="filter" chain="SURICATA_HOST_OUTPUT" priority="6">-j NFQUEUE --queue-num 0</rule>

  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="0">-m conntrack --ctstate ESTABLISHED,RELATED -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="1">-i lo -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="2">-i virbr+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="3">-i vnet+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="4">-i podman+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="5">-i cni+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_INPUT" priority="6">-j NFQUEUE --queue-num 0</rule>

  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="0">-m conntrack --ctstate ESTABLISHED,RELATED -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="1">-o lo -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="2">-o virbr+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="3">-o vnet+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="4">-o podman+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="5">-o cni+ -j RETURN</rule>
  <rule ipv="ipv6" table="filter" chain="SURICATA_HOST_OUTPUT" priority="6">-j NFQUEUE --queue-num 0</rule>
</direct>
