FROM quay.io/fedora/fedora-coreos:stable

LABEL org.opencontainers.image.title="Workstation"
LABEL org.opencontainers.image.description="Nick's bootable container"

RUN set -euxo pipefail; \
  rpm-ostree override remove nfs-utils-coreos; \
  rpm-ostree install -y \
    cachefilesd \
    NetworkManager-wifi NetworkManager-bluetooth NetworkManager-wwan NetworkManager-cloud-setup \
    accountsservice \
    aemu libvirt qemu-kvm android-tools \
    gdm \
    glibc-all-langpacks \
    gnome-backgrounds gnome-control-center gnome-disk-utility gnome-initial-setup \
    gnome-keyring gnome-menus gnome-session gnome-shell \
    nautilus nautilus-python python3-pygit2 nautilus-gsconnect sushi \
    seahorse-nautilus tnef-nautilus papers-nautilus \
    xdg-desktop-portal xdg-desktop-portal-gtk \
    pipewire wireplumber \
    plymouth plymouth-theme-spinner \
    power-profiles-daemon upower nut \
    cups bluez dconf dbus-daemon \
    flatpak flatpak-spawn \
    fuse fuse-libs \
    jq curl \
    toolbox git \
    tracker-miners ffmpegthumbnailer gstreamer1-libav gstreamer1-plugin-openh264 \
    mesa-dri-drivers switcheroo-control virglrenderer \
    libhid hidapi openrgb-udev-rules \
    steam-devices \
    ptyxis browserpass pass pass-otp pass-audit python-pass-import; \

  rm -rf /var/cache/rpm-ostree /var/lib/rpm-ostree/cache /var/cache/dnf; \
  ostree container commit

RUN set -euxo pipefail; \
  mkdir -p \
    /etc/skel/.bashrc.d \
    /etc/systemd/system/graphical.target.wants \
    /etc/systemd/system/multi-user.target.wants \
    /etc/sysconfig \
    /var/lib/AccountsService \
    /etc/polkit-1/rules.d \
    /etc/NetworkManager/system-connections \
    /etc/dconf/db/local.d \
    /usr/share/gnome-background-properties

COPY *.nmconnection /etc/NetworkManager/system-connections/
COPY background.png /usr/share/backgrounds/nick-wallpaper.png
COPY background.xml /usr/share/gnome-background-properties/nick.xml
COPY cachefilesd.conf /etc/cachefilesd.conf
COPY libvirtd.conf /etc/libvirt/libvirtd.conf
COPY nftables.conf /etc/nftables.conf
COPY passwordstore.sh /passwordstore.sh
COPY polkit.rules /etc/polkit-1/rules.d/50-libvirt-access.rules
COPY profile.conf /var/lib/AccountsService/default
COPY profile.png /usr/share/pixmaps/faces/nick.png
COPY skel /etc/skel

RUN set -euxo pipefail; \
  dconf update; \

  chmod +x /passwordstore.sh; \
  /passwordstore.sh; \
  rm -f /passwordstore.sh; \

  chmod 0600 /etc/NetworkManager/system-connections/*.nmconnection; \
  chmod 0644 /etc/nftables.conf; \
  chmod 0644 /etc/polkit-1/rules.d/50-libvirt-access.rules; \

  rm -f /etc/resolv.conf; \
  ln -s /run/NetworkManager/resolv.conf /etc/resolv.conf; \

  ln -sf /usr/lib/systemd/system/gdm.service \
    /etc/systemd/system/graphical.target.wants/gdm.service; \
  ln -sf /usr/lib/systemd/system/graphical.target \
    /etc/systemd/system/default.target; \
  ln -sf /usr/lib/systemd/system/libvirtd.service \
    /etc/systemd/system/multi-user.target.wants/libvirtd.service; \
  ln -sf /usr/lib/systemd/system/virtlockd.service \
    /etc/systemd/system/multi-user.target.wants/virtlockd.service; \
  ln -sf /usr/lib/systemd/system/virtlogd.service \
    /etc/systemd/system/multi-user.target.wants/virtlogd.service; \

  printf '%s\n' "INITIAL_SETUP_ENABLE=YES" > /etc/sysconfig/initial-setup; \
  ostree container commit