# Copy to /etc/ups/netclient.env and fill in values from UniFi.
# Keep the real file mode 0640 or stricter; it contains credentials.
NUT_UPS_HOST=ups.example.lan
NUT_UPS_NAME=UPS
NUT_UPS_PORT=3493
NUT_MONITOR_USER=nut
NUT_MONITOR_PASSWORD=nut
NUT_POWER_VALUE=1
NUT_ROLE=secondary
# NUT_SHUTDOWNCMD=/usr/sbin/shutdown -h +0
