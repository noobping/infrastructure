#!/usr/bin/env bash
set -euo pipefail

if ! command -v fapolicyd-cli >/dev/null 2>&1; then
  exit 0
fi

exec 9>/run/fapolicyd-flatpak-sync.lock
flock -n 9 || exit 0

synced=0
for flatpak_root in /var/lib/flatpak/app /var/lib/flatpak/runtime; do
  [ -d "$flatpak_root" ] || continue

  # Only trust the deployed system Flatpak trees. User-writable paths stay untrusted.
  fapolicyd-cli --file delete "$flatpak_root" >/dev/null 2>&1 || true
  fapolicyd-cli --file add "$flatpak_root"
  synced=1
done

[ "$synced" -eq 1 ] || exit 0

if systemctl is-active --quiet fapolicyd.service; then
  fapolicyd-cli --update
fi
