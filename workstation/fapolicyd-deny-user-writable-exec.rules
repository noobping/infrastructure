# Block direct execution from locations normal users can write to.
# System Flatpaks are trusted through the fapolicyd Flatpak sync service.
deny_audit perm=execute all : dir=/home/
deny_audit perm=execute all : dir=/var/home/
deny_audit perm=execute all : dir=/tmp/
deny_audit perm=execute all : dir=/var/tmp/
deny_audit perm=execute all : dir=/dev/shm/
deny_audit perm=execute all : dir=/run/user/
deny_audit perm=execute all : dir=/media/
deny_audit perm=execute all : dir=/mnt/
deny_audit perm=execute all : dir=/run/media/
