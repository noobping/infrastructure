#!/usr/bin/env bash
set -euo pipefail

if ! command -v fapolicyd-cli >/dev/null 2>&1; then
  exit 0
fi

if ! systemctl is-enabled --quiet fapolicyd.service && \
   ! systemctl is-active --quiet fapolicyd.service; then
  exit 0
fi

if [[ "${EUID}" -ne 0 ]]; then
  echo "This helper must be run as root." >&2
  exit 1
fi

uid_arg="${1:-}"
home_arg="${2:-}"
pkexec_uid="${PKEXEC_UID:-}"

if [[ ! "$uid_arg" =~ ^[0-9]+$ ]]; then
  echo "Expected numeric uid argument." >&2
  exit 1
fi

if [[ -z "$home_arg" || "$home_arg" != /* ]]; then
  echo "Expected absolute home directory argument." >&2
  exit 1
fi

if [[ ! "$pkexec_uid" =~ ^[0-9]+$ ]]; then
  echo "Missing invoking user identity." >&2
  exit 1
fi

if [[ "$uid_arg" != "$pkexec_uid" ]]; then
  echo "Refusing to sync trust for another user." >&2
  exit 1
fi

passwd_entry="$(getent passwd "$pkexec_uid" || true)"
if [[ -z "$passwd_entry" ]]; then
  echo "Unable to resolve invoking user." >&2
  exit 1
fi

expected_home="$(printf '%s\n' "$passwd_entry" | cut -d: -f6)"
if [[ -z "$expected_home" || "$expected_home" != /* ]]; then
  echo "Unable to resolve invoking home directory." >&2
  exit 1
fi

if [[ "$home_arg" != "$expected_home" ]]; then
  echo "Refusing to sync trust for another home directory." >&2
  exit 1
fi

sync_root() {
  local root="$1"

  [[ -d "$root" ]] || return 0

  root="${root%/}/"
  fapolicyd-cli --file delete "$root" >/dev/null 2>&1 || true
  fapolicyd-cli --file add "$root"
  return 0
}

synced=0
for root in \
  "$expected_home/.local/share/containers/storage" \
  "/run/user/$uid_arg/containers" \
  "/tmp/containers-user-$uid_arg/containers"; do
  if [[ -d "$root" ]]; then
    sync_root "$root"
    synced=1
  fi
done

if [[ "$synced" -eq 1 ]]; then
  fapolicyd-cli --update
fi
